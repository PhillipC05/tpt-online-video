# TPT Online Video local development defaults

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tpt
POSTGRES_USER=tpt
POSTGRES_PASSWORD=tpt

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=./data/storage
S3_ENDPOINT=
S3_BUCKET=tpt-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_USE_PATH_STYLE=true

JWT_SECRET=change-me-in-development
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

MEDIA_STREAM_BASE_URL=http://localhost:8080
LIVE_HLS_BASE_URL=http://localhost:8888
LIVE_WEBRTC_BASE_URL=http://localhost:8889

# IPFS
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080
IPFS_PROFILE=server
